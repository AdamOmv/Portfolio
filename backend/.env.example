PORT=4000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=portfolio_user
DB_PASSWORD=your_password_here
DB_NAME=portfolio_adomv

# JWT
JWT_SECRET=change_this_to_a_very_long_random_string_256_bits
JWT_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=/home/ubuntu/portfolio_adomv/uploads
MAX_FILE_SIZE=5242880

# CORS
FRONTEND_URL=http://localhost:5173

# Email (optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=admin@adomv.com

# URL publique optionnelle pour les liens d'uploads
BASE_URL=

# Bootstrap admin optionnel
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
